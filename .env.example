# SSH Configuration
SSH_USER=deploy

# Docker host address for container-to-host SSH communication
# This is automatically detected during installation
# Default: 172.17.0.1 (standard Docker bridge)
# Jetson/Tegra: 172.21.0.1 (custom address pool to avoid VPN conflicts)
HOST_ADDRESS=172.17.0.1

# roma-matcher Harbor pull credential (OPT-IN gate for the up-1.0.79 migration).
# Set this ONLY on machines that should run roma-matcher (production rocket-welder hosts).
# When present, the AutoUpdater self-update auto-registers roma-matcher; when absent, the
# migration skips this device. It is a base64-encoded "username:password" registry token,
# from a Harbor robot account with pull access to roma-matcher/roma-matcher. Build it with:
#   echo -n 'robot$roma-matcher+pull:HARBOR_ROBOT_TOKEN' | base64
# NEVER commit the real value.
ROMA_MATCHER_DOCKER_AUTH=